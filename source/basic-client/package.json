{
  "name": "basic-client",
  "version": "1.0.0",
  "description": "基础服务客户端",
  "scripts": {
    "build": "webpack --config webpack.pro.js",
    "dev": "webpack --config webpack.dev.js --watch",
    "clean": "npm run clean_ccxc && npm run clean_lock",
    "clean_ccxc": "if exist .\\node_modules\\@ccxc del /s /q .\\node_modules\\@ccxc && if exist .\\node_modules\\@ccxc rd /s /q .\\node_modules\\@ccxc",
    "clean_lock": "if exist .\\package-lock.json del /s /q .\\package-lock.json"
  },
  "author": "小程",
  "license": "ISC",
  "dependencies": {
    "@ccxc/tool": "1.0.3",
    "jquery": "^3.5.1",
    "marked": "^13.0.2"
  },
  "devDependencies": {
    "babel-preset-stage-0": "^6.24.1",
    "babel-preset-es2015": "^6.24.1",
    "babel-core": "^6.26.3",
    "babel-loader": "^7.1.5",
    "babel-plugin-transform-runtime": "^6.23.0",
    "babel-polyfill": "^6.26.0",
    "copy-webpack-plugin": "^9.0.1",
    "css-loader": "^6.4.0",
    "html-webpack-plugin": "^5.4.0",
    "less": "^4.1.2",
    "less-loader": "^10.2.0",
    "mini-css-extract-plugin": "^2.4.2",
    "style-loader": "^3.3.0",
    "webpack": "^5.59.0",
    "webpack-cli": "^4.9.1",
    "webpack-merge": "^5.8.0"
  }
}
